# Production Environment Variables for Vercel
# Add these in your Vercel project settings under "Environment Variables"

# REQUIRED: Vessel Arrivals API Key (Subscription-based)
# Get this from the Oceans-X portal at https://oceans-x.mpa.gov.sg/
# Go to My Applications > Subscriptions > Vessel Arrivals API
VMS_ARRIVALS_API_KEY=your_subscription_api_key_jwt_here

# Optional: API base URL (not needed for Vercel - uses relative paths)
# VITE_API_BASE=/api
