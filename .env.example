# API base used by the frontend; set to your Mulesoft sandbox or mock
VITE_API_BASE=http://localhost:3000

# Vessel Arrivals API Key - Server-side ONLY (used by /api/arrivals proxy)
# Do NOT prefix with VITE_ - this must remain server-side only and never exposed to browser
# Get this from the Oceans-X portal at https://oceans-x.mpa.gov.sg/
# Note: This is legacy ApiKey authentication. OAuth2 credentials below are preferred for production.
VMS_ARRIVALS_API_KEY=your_api_key_here

# OAuth2 Production Credentials (Oceans-X API)
# Consumer Key for OAuth2 client identification
VITE_OAUTH_CONSUMER_KEY=your_consumer_key_here

# Consumer Secret for OAuth2 flow (keep secret, server-side only)
VITE_OAUTH_CONSUMER_SECRET=your_consumer_secret_here

# Token endpoint for OAuth2 authorization server
VITE_OAUTH_TOKEN_ENDPOINT=https://oceans-x.mpa.gov.sg/oauth2/token

# OAuth2 Access Token (JWT) - valid for vessel arrivals API calls
# Obtain by exchanging Consumer Key/Secret at the token endpoint
# Token expires after a certain time - implement token refresh logic for long-lived applications
VITE_OAUTH_ACCESS_TOKEN=your_access_token_jwt_here

# If true, the browser will send updates directly to the external Cloudhub endpoint
# Note: the external endpoint must allow CORS for this to work. If false (default),
# the app uses the local server proxy (`npm run mock:server`) which forwards updates.
VITE_DIRECT_FORWARD=true

# The external Cloudhub URL to use when VITE_DIRECT_FORWARD=true
VITE_EXTERNAL_UPDATE_URL=https://vms-data-processing-jgjm9r.5sc6y6-4.usa-e2.cloudhub.io/api/update

# Base path for GitHub Pages deployment
# Set to /vessel-arrival-report-web/ when deploying to GitHub Pages
VITE_BASE_PATH=/

