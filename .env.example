# API base used by the frontend; set to your Mulesoft sandbox or mock
VITE_API_BASE=http://localhost:3000
# If your API uses an API key, set it here; the client will send it as 'x-api-key'
VITE_API_KEY=

# Vessel Arrivals API Key - Server-side ONLY (used by /api/arrivals proxy)
# Do NOT prefix with VITE_ - this must remain server-side only and never exposed to browser
# Get this from the Oceans-X portal at https://oceans-x.mpa.gov.sg/
VMS_ARRIVALS_API_KEY=your_api_key_here

# If true, the browser will send updates directly to the external Cloudhub endpoint
# Note: the external endpoint must allow CORS for this to work. If false (default),
# the app uses the local server proxy (`npm run mock:server`) which forwards updates.
VITE_DIRECT_FORWARD=true
# The external Cloudhub URL to use when VITE_DIRECT_FORWARD=true
VITE_EXTERNAL_UPDATE_URL=https://vms-data-processing-jgjm9r.5sc6y6-4.usa-e2.cloudhub.io/api/update
